---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import HeroDefault from '../../assets/blog-placeholder-1.jpg';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const publicImageMap: Record<string, string> = {
  'recetas-altas-en-proteina-para-ganar-musculo': '/portada.png',
};
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead
      title={`Blog de Fitness — Rutinas, Nutrición y Consejos | ${SITE_TITLE}`}
      description={SITE_DESCRIPTION}
      seoDescription="Artículos de fitness, rutinas de entrenamiento, nutrición deportiva y consejos prácticos para transformar tu cuerpo y tu vida. Guías escritas por profesionales."
    />
  </head>
  <body>
    <Header />
    <main>
      <section class="blog-header">
        <span class="section-label">Blog</span>
        <h1>Artículos de Fitness</h1>
        <p>Rutinas, nutrición y consejos para transformar tu cuerpo y tu vida.</p>
      </section>

      <div class="posts-grid">
        {posts.map((post) => {
          const publicImage = publicImageMap[post.id];
          return (
            <a href={`/blog/${post.id}/`} class="post-card">
              <div class="post-image">
                {publicImage ? (
                  <img src={publicImage} alt="" width="720" height="400" loading="lazy" decoding="async" />
                ) : (
                  <Image width={720} height={400} src={HeroDefault} alt="" />
                )}
              </div>
              <div class="post-body">
                {post.data.category && (
                  <span class="post-category">{post.data.category}</span>
                )}
                <time class="post-date"><FormattedDate date={post.data.pubDate} /></time>
                <h2>{post.data.title}</h2>
                <p>{post.data.seoDescription ?? post.data.description}</p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="post-tags-preview">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class="tag">#{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          );
        })}
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .blog-header {
    margin-bottom: 3rem;
  }
  .blog-header h1 {
    margin-bottom: 0.75rem;
  }
  .blog-header p {
    font-size: 1.1rem;
    max-width: 500px;
  }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }
  .post-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--bg-elevated);
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.3s;
  }
  .post-card:hover {
    border-color: rgba(34, 197, 94, 0.3);
    transform: translateY(-4px);
  }
  .post-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
  .post-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    transition: transform 0.4s;
  }
  .post-card:hover .post-image img {
    transform: scale(1.05);
  }
  .post-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .post-category {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    font-weight: 600;
  }
  .post-date {
    font-size: 0.8rem;
    color: rgb(var(--gray));
  }
  .post-body h2 {
    font-size: 1.25rem;
    margin: 0;
    color: #ffffff;
  }
  .post-body p {
    font-size: 0.85rem;
    color: rgb(var(--gray));
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-tags-preview {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }
  .tag {
    font-size: 0.75rem;
    color: rgb(var(--gray));
  }
</style>

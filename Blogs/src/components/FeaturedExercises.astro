---
import Icon from './Icon.astro';
import { getFeaturedExercises } from '../lib/exercises';

const exercises = getFeaturedExercises(8);
---

<section class="section popular-exercises">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="section-label">Explora</span>
        <h2>Ejercicios populares</h2>
        <p>Una selección de los ejercicios más consultados de nuestro catálogo. Cada uno incluye animación, técnica e instrucciones paso a paso.</p>
      </div>
      <a href="/ejercicios" class="btn btn-outline">
        Ver catálogo
        <Icon name="arrow-right" size={16} strokeWidth={2.5} />
      </a>
    </div>

    <div class="exercises-grid">
      {exercises.map((ex) => (
        <a href={`/ejercicios/${ex.id}/`} class="ex-card">
          <div class="ex-image">
            <img src={ex.image} alt={ex.name} loading="lazy" width="180" height="180" />
          </div>
          <div class="ex-body">
            <span class="ex-target">{ex.targetLabel}</span>
            <h3>{ex.name}</h3>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }
  .section-head h2 {
    margin: 0.25rem 0 0.5rem;
  }
  .section-head p {
    color: rgb(var(--gray));
    max-width: 560px;
    margin: 0;
  }
  .exercises-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .ex-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--bg-elevated);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.2s;
  }
  .ex-card:hover {
    border-color: rgba(34, 197, 94, 0.4);
    transform: translateY(-2px);
  }
  .ex-image {
    aspect-ratio: 1;
    background: #fff;
  }
  .ex-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 0;
  }
  .ex-body {
    padding: 0.85rem 1rem;
  }
  .ex-target {
    font-family: var(--font-heading);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    font-weight: 600;
  }
  .ex-body h3 {
    margin: 0.25rem 0 0;
    font-size: 0.9rem;
    color: #ffffff;
    text-transform: none;
    letter-spacing: 0;
    font-family: var(--font-body);
    font-weight: 500;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (max-width: 880px) {
    .exercises-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

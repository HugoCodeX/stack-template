---
interface Props {
  slot: string;
  format?: 'auto' | 'fluid' | 'rectangle' | 'vertical' | 'horizontal';
  style?: 'display:block' | 'display:inline-block' | 'display:flex';
  layout?: string;
  layoutKey?: string;
  responsive?: boolean;
  className?: string;
  label?: string;
}

const {
  slot,
  format = 'auto',
  style = 'display:block',
  layout,
  layoutKey,
  responsive = true,
  className = '',
  label = 'Anuncio',
} = Astro.props;
---

<aside class={`ad-slot ${className}`} aria-label={label}>
  <span class="ad-label">Publicidad</span>
  <ins
    class="adsbygoogle"
    style={style}
    data-ad-client="ca-pub-8232468059197740"
    data-ad-slot={slot}
    data-ad-format={format}
    data-full-width-responsive={responsive ? 'true' : 'false'}
    data-ad-layout={layout}
    data-ad-layout-key={layoutKey}
  ></ins>
</aside>

<script is:inline>
  (function pushAd() {
    try {
      var slots = document.querySelectorAll('.adsbygoogle:not([data-ad-pushed])');
      for (var i = 0; i < slots.length; i++) {
        slots[i].setAttribute('data-ad-pushed', 'true');
        (window.adsbygoogle = window.adsbygoogle || []).push({});
      }
    } catch (e) {
      console.error('AdSense push error:', e);
    }
  })();
  document.addEventListener('DOMContentLoaded', pushAd);
</script>

<style>
  .ad-slot {
    display: block;
    margin: 2.5rem auto;
    padding: 1rem;
    background: var(--bg-card);
    border: 1px dashed var(--bg-elevated);
    border-radius: 12px;
    min-height: 100px;
    text-align: center;
    max-width: 100%;
  }
  .ad-label {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgb(var(--gray));
    margin-bottom: 0.5rem;
  }
  .ad-slot ins {
    margin: 0 auto;
  }
</style>

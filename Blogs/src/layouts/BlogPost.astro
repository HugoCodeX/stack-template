---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Icon from '../components/Icon.astro';
import HeroDefault from '../assets/blog-placeholder-1.jpg';

type Props = CollectionEntry<'blog'>['data'];

const {
  title,
  description,
  seoDescription,
  pubDate,
  updatedDate,
  heroImage,
  category,
  tags,
} = Astro.props;

const publicImageMap: Record<string, string> = {
  'recetas-altas-en-proteina-para-ganar-musculo': '/portada.png',
};
const publicHeroImage = publicImageMap[Astro.params.slug ?? ''];

const heroImageUrl = heroImage?.src ?? publicHeroImage;
const heroImagePublic = !heroImage && !!publicHeroImage;
---

<html lang="es">
  <head>
    <BaseHead
      title={title}
      description={description}
      seoDescription={seoDescription}
      category={category}
      tags={tags}
      pubDate={pubDate}
      updatedDate={updatedDate}
      type="article"
    />
  </head>
  <body>
    <Header />
    <main>
      <article class="post-article">
        {category && (
          <a href={`/blog?category=${encodeURIComponent(category.toLowerCase())}`} class="post-category">
            {category}
          </a>
        )}
        <header class="post-header">
          <div class="post-meta">
            <time><FormattedDate date={pubDate} /></time>
            {updatedDate && (
              <span class="updated">Actualizado <FormattedDate date={updatedDate} /></span>
            )}
          </div>
          <h1>{title}</h1>
          <p class="post-description">{seoDescription ?? description}</p>
        </header>
        {heroImageUrl && (
          <div class="post-hero">
            {heroImagePublic ? (
              <img src={heroImageUrl} alt="" width="1200" height="630" loading="eager" decoding="async" />
            ) : (
              <Image width={1200} height={630} src={heroImage ?? HeroDefault} alt="" />
            )}
          </div>
        )}
        <div class="prose">
          <slot />
        </div>
        {tags && tags.length > 0 && (
          <footer class="post-tags">
            <span class="tags-label">Etiquetas:</span>
            <ul>
              {tags.map((tag) => (
                <li>
                  <a href={`/blog?tag=${encodeURIComponent(tag.toLowerCase().replace(/\s+/g, '-'))}`}>
                    #{tag}
                  </a>
                </li>
              ))}
            </ul>
          </footer>
        )}
        <nav class="post-share" aria-label="Compartir artículo">
          <span>Compartir:</span>
          <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${Astro.url}`} target="_blank" rel="noopener noreferrer" aria-label="Compartir en Twitter">
            <Icon name="twitter" size={18} />
          </a>
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${Astro.url}`} target="_blank" rel="noopener noreferrer" aria-label="Compartir en Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href={`https://wa.me/?text=${encodeURIComponent(title + ' ' + Astro.url)}`} target="_blank" rel="noopener noreferrer" aria-label="Compartir en WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          </a>
        </nav>
      </article>
    </main>
    <Footer />
  </body>
</html>

<style>
  .post-article {
    max-width: 720px;
    margin: 0 auto;
  }
  .post-category {
    display: inline-block;
    padding: 0.4rem 0.9rem;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    color: var(--accent);
    font-family: var(--font-heading);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    border-radius: 100px;
    margin-bottom: 1.5rem;
    text-decoration: none;
    transition: all 0.2s;
  }
  .post-category:hover {
    background: var(--accent);
    color: #000;
    opacity: 1;
  }
  .post-header {
    margin-bottom: 2rem;
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
  }
  .post-meta time {
    color: var(--accent);
  }
  .updated {
    color: rgb(var(--gray));
    font-size: 0.8rem;
  }
  .post-header h1 {
    margin-bottom: 0.75rem;
  }
  .post-description {
    font-size: 1.15rem;
    color: rgb(var(--gray));
    line-height: 1.6;
  }
  .post-hero {
    margin-bottom: 2.5rem;
    border-radius: 16px;
    overflow: hidden;
  }
  .post-hero img {
    width: 100%;
    border-radius: 0;
  }
  .prose {
    color: rgb(var(--gray-dark));
    line-height: 1.8;
    font-size: 1.05rem;
  }
  .prose p {
    margin-bottom: 1.5em;
  }
  .prose h2 {
    margin-top: 2em;
    margin-bottom: 0.75em;
  }
  .prose h3 {
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }
  .prose img {
    border-radius: 12px;
    margin: 2rem 0;
  }
  .prose a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose ul, .prose ol {
    padding-left: 1.5rem;
    margin-bottom: 1.5em;
  }
  .prose li {
    margin-bottom: 0.5em;
  }
  .prose blockquote {
    margin: 2rem 0;
    padding: 1rem 1.5rem;
    background: var(--bg-card);
    border-radius: 8px;
    border-left: 4px solid var(--accent);
  }
  .prose blockquote p {
    margin: 0;
  }
  .prose hr {
    margin: 2.5rem 0;
  }
  .post-tags {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--bg-elevated);
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .tags-label {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgb(var(--gray));
  }
  .post-tags ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .post-tags a {
    display: inline-block;
    padding: 0.4rem 0.9rem;
    background: var(--bg-card);
    border: 1px solid var(--bg-elevated);
    color: rgb(var(--gray-dark));
    border-radius: 100px;
    font-size: 0.85rem;
    text-decoration: none;
    transition: all 0.2s;
  }
  .post-tags a:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(34, 197, 94, 0.08);
  }
  .post-share {
    margin-top: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: rgb(var(--gray));
  }
  .post-share a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--bg-card);
    border: 1px solid var(--bg-elevated);
    color: rgb(var(--gray));
    transition: all 0.2s;
  }
  .post-share a:hover {
    background: var(--accent);
    color: #000;
    border-color: var(--accent);
    transform: translateY(-2px);
  }
</style>
